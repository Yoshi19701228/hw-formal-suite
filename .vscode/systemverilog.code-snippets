{
  // ============================================================
  // Simulator Mode
  // ============================================================

  "SVA [SIM] Property Block": {
    "prefix": "sva-sim-prop",
    "scope": "systemverilog,verilog",
    "description": "[Simulator] property + assert + cover",
    "body": [
      "// ${1:何を検証するか}",
      "property prop_${2:name};",
      "  @(posedge ${3:clk}) disable iff (!${4:rst_n})",
      "  ${5:antecedent} |-> ${6:consequent};",
      "endproperty",
      "",
      "AST_${2/(.*)/${1:/upcase}/}: assert property (prop_${2:name})",
      "  else \\$error(\"[ASSERT FAIL] ${2/(.*)/${1:/upcase}/}: %t\", \\$time);",
      "COV_${2/(.*)/${1:/upcase}/}: cover property (prop_${2:name});"
    ]
  },

  "SVA [SIM] Handshake": {
    "prefix": "sva-sim-handshake",
    "scope": "systemverilog,verilog",
    "description": "[Simulator] valid/ready handshake stability",
    "body": [
      "// valid が High の間、ready が来るまで valid を保持",
      "property prop_${1:valid}_stable;",
      "  @(posedge ${2:clk}) disable iff (!${3:rst_n})",
      "  (${1:valid} && !${4:ready}) |=> ${1:valid};",
      "endproperty",
      "",
      "AST_${1/(.*)/${1:/upcase}/}_STABLE: assert property (prop_${1:valid}_stable)",
      "  else \\$error(\"[ASSERT FAIL] ${1/(.*)/${1:/upcase}/}_STABLE: dropped before ready at %t\", \\$time);",
      "COV_${1/(.*)/${1:/upcase}/}_STABLE: cover property (prop_${1:valid}_stable);"
    ]
  },

  "SVA [SIM] Req/Ack Timeout": {
    "prefix": "sva-sim-req-ack",
    "scope": "systemverilog,verilog",
    "description": "[Simulator] req → ack within N cycles (##[1:N])",
    "body": [
      "// ${1:req} から ${2:16} サイクル以内に ${3:ack} が来ること",
      "property prop_${1:req}_${3:ack}_timeout;",
      "  @(posedge ${4:clk}) disable iff (!${5:rst_n})",
      "  \\$rose(${1:req}) |-> ##[1:${2:16}] ${3:ack};",
      "endproperty",
      "",
      "AST_${1/(.*)/${1:/upcase}/}_${3/(.*)/${1:/upcase}/}: assert property (prop_${1:req}_${3:ack}_timeout)",
      "  else \\$error(\"[ASSERT FAIL] timeout at %t\", \\$time);",
      "COV_${1/(.*)/${1:/upcase}/}_${3/(.*)/${1:/upcase}/}: cover property (prop_${1:req}_${3:ack}_timeout);"
    ]
  },

  "SVA [SIM] FIFO": {
    "prefix": "sva-sim-fifo",
    "scope": "systemverilog,verilog",
    "description": "[Simulator] FIFO overflow/underflow",
    "body": [
      "// FIFO オーバーフロー・アンダーフロー保護",
      "property prop_no_push_when_full;",
      "  @(posedge ${1:clk}) disable iff (!${2:rst_n})",
      "  ${3:full} |-> !${4:push};",
      "endproperty",
      "",
      "property prop_no_pop_when_empty;",
      "  @(posedge ${1:clk}) disable iff (!${2:rst_n})",
      "  ${5:empty} |-> !${6:pop};",
      "endproperty",
      "",
      "AST_NO_PUSH_FULL:  assert property (prop_no_push_when_full)",
      "  else \\$error(\"[ASSERT FAIL] NO_PUSH_FULL: %t\", \\$time);",
      "AST_NO_POP_EMPTY:  assert property (prop_no_pop_when_empty)",
      "  else \\$error(\"[ASSERT FAIL] NO_POP_EMPTY: %t\", \\$time);",
      "COV_NO_PUSH_FULL:  cover property (prop_no_push_when_full);",
      "COV_NO_POP_EMPTY:  cover property (prop_no_pop_when_empty);"
    ]
  },

  // ============================================================
  // Formal Verification Mode
  // ============================================================

  "SVA [FORMAL] Property Block": {
    "prefix": "sva-fml-prop",
    "scope": "systemverilog,verilog",
    "description": "[Formal] property + assert (safety) + cover (reachability)",
    "body": [
      "// ${1:何を検証するか}",
      "property prop_${2:name};",
      "  @(posedge ${3:clk}) disable iff (!${4:rst_n})",
      "  ${5:antecedent} |-> ${6:consequent};",
      "endproperty",
      "",
      "// Safety",
      "AST_${2/(.*)/${1:/upcase}/}: assert property (prop_${2:name});",
      "",
      "// Reachability",
      "COV_${2/(.*)/${1:/upcase}/}_TRIGGER: cover property (@(posedge ${3:clk}) ${5:antecedent});",
      "COV_${2/(.*)/${1:/upcase}/}_SUCCESS: cover property (@(posedge ${3:clk}) ${5:antecedent} ##1 ${6:consequent});"
    ]
  },

  "SVA [FORMAL] Assume Property": {
    "prefix": "sva-fml-assume",
    "scope": "systemverilog,verilog",
    "description": "[Formal] Environment assumption (assume property)",
    "body": [
      "// 環境制約: ${1:説明}",
      "property assume_${2:name};",
      "  @(posedge ${3:clk}) disable iff (!${4:rst_n})",
      "  ${5:condition};",
      "endproperty",
      "",
      "ENV_${2/(.*)/${1:/upcase}/}: assume property (assume_${2:name});"
    ]
  },

  "SVA [FORMAL] Handshake": {
    "prefix": "sva-fml-handshake",
    "scope": "systemverilog,verilog",
    "description": "[Formal] valid/ready stability + assume ready eventually",
    "body": [
      "// valid 安定性",
      "property prop_${1:valid}_stable;",
      "  @(posedge ${2:clk}) disable iff (!${3:rst_n})",
      "  (${1:valid} && !${4:ready}) |=> ${1:valid};",
      "endproperty",
      "",
      "property prop_${1:valid}_data_stable;",
      "  @(posedge ${2:clk}) disable iff (!${3:rst_n})",
      "  (${1:valid} && !${4:ready}) |=> \\$stable(${5:data});",
      "endproperty",
      "",
      "// Safety",
      "AST_${1/(.*)/${1:/upcase}/}_STABLE:      assert property (prop_${1:valid}_stable);",
      "AST_${1/(.*)/${1:/upcase}/}_DATA_STABLE: assert property (prop_${1:valid}_data_stable);",
      "",
      "// Reachability",
      "COV_HANDSHAKE:          cover property (@(posedge ${2:clk}) ${1:valid} && ${4:ready});",
      "COV_VALID_WAIT:         cover property (@(posedge ${2:clk}) ${1:valid} && !${4:ready});",
      "COV_WAIT_THEN_DONE:     cover property (@(posedge ${2:clk}) (${1:valid} && !${4:ready}) ##1 (${1:valid} && ${4:ready}));",
      "",
      "// 環境制約: ready は ${6:32} サイクル以内に来る",
      "property assume_${4:ready}_eventually;",
      "  @(posedge ${2:clk}) disable iff (!${3:rst_n})",
      "  ${1:valid} |-> ##[1:${6:32}] ${4:ready};",
      "endproperty",
      "",
      "ENV_${4/(.*)/${1:/upcase}/}_EVENTUALLY: assume property (assume_${4:ready}_eventually);"
    ]
  },

  "Verilog [FORMAL] Timeout Counter Helper": {
    "prefix": "sva-fml-cnt-helper",
    "scope": "systemverilog,verilog",
    "description": "[Formal] Verilog counter helper for req/ack timeout (replaces ##[1:N])",
    "body": [
      "// ============================================================",
      "// [Helper Logic] ${1:req} pending cycle counter",
      "// ============================================================",
      "module ${2:req_ack}_helper #(parameter MAX_LATENCY = ${3:16}) (",
      "  input  wire clk,",
      "  input  wire rst_n,",
      "  input  wire ${1:req},",
      "  input  wire ${4:ack},",
      "  output reg  [\\$clog2(MAX_LATENCY+1)-1:0] cnt_${1:req}_pending,",
      "  output reg  timeout",
      ");",
      "  always @(posedge clk or negedge rst_n) begin",
      "    if (!rst_n) begin",
      "      cnt_${1:req}_pending <= '0;",
      "      timeout              <= 1'b0;",
      "    end else begin",
      "      if (${1:req} && !${4:ack})",
      "        cnt_${1:req}_pending <= cnt_${1:req}_pending + 1;",
      "      else",
      "        cnt_${1:req}_pending <= '0;",
      "",
      "      timeout <= (cnt_${1:req}_pending >= MAX_LATENCY - 1) && ${1:req} && !${4:ack};",
      "    end",
      "  end",
      "endmodule",
      "",
      "// --- SVA (timeout 信号を参照) ---",
      "property prop_no_timeout;",
      "  @(posedge clk) disable iff (!rst_n)",
      "  !timeout;",
      "endproperty",
      "",
      "AST_NO_TIMEOUT: assert property (prop_no_timeout);"
    ]
  },

  "Verilog [FORMAL] Shift Register Helper": {
    "prefix": "sva-fml-sr-helper",
    "scope": "systemverilog,verilog",
    "description": "[Formal] Verilog shift register helper (replaces $past(sig, N))",
    "body": [
      "// ============================================================",
      "// [Helper Logic] ${1:data} ${2:4}-cycle shift register",
      "// ============================================================",
      "module ${1:data}_delay_helper #(",
      "  parameter DEPTH = ${2:4},",
      "  parameter WIDTH = ${3:32}",
      ") (",
      "  input  wire              clk,",
      "  input  wire              rst_n,",
      "  input  wire [WIDTH-1:0]  ${1:data}_in,",
      "  output wire [WIDTH-1:0]  ${1:data}_dN",
      ");",
      "  reg [WIDTH-1:0] sr_${1:data} [0:DEPTH-1];",
      "  integer i;",
      "",
      "  always @(posedge clk or negedge rst_n) begin",
      "    if (!rst_n) begin",
      "      for (i = 0; i < DEPTH; i = i + 1)",
      "        sr_${1:data}[i] <= '0;",
      "    end else begin",
      "      sr_${1:data}[0] <= ${1:data}_in;",
      "      for (i = 1; i < DEPTH; i = i + 1)",
      "        sr_${1:data}[i] <= sr_${1:data}[i-1];",
      "    end",
      "  end",
      "",
      "  assign ${1:data}_dN = sr_${1:data}[DEPTH-1];",
      "endmodule"
    ]
  },

  "Verilog [FORMAL] Outstanding Counter Helper": {
    "prefix": "sva-fml-out-helper",
    "scope": "systemverilog,verilog",
    "description": "[Formal] Verilog outstanding transaction counter helper",
    "body": [
      "// ============================================================",
      "// [Helper Logic] outstanding transaction counter",
      "// ============================================================",
      "module ${1:txn}_outstanding_helper #(parameter MAX_OUT = ${2:16}) (",
      "  input  wire clk,",
      "  input  wire rst_n,",
      "  input  wire req,",
      "  input  wire ack,",
      "  output reg  [\\$clog2(MAX_OUT+1)-1:0] cnt_outstanding,",
      "  output reg  overflow,",
      "  output reg  underflow",
      ");",
      "  always @(posedge clk or negedge rst_n) begin",
      "    if (!rst_n) begin",
      "      cnt_outstanding <= '0;",
      "      overflow        <= 1'b0;",
      "      underflow       <= 1'b0;",
      "    end else begin",
      "      case ({req, ack})",
      "        2'b10: cnt_outstanding <= cnt_outstanding + 1;",
      "        2'b01: cnt_outstanding <= cnt_outstanding - 1;",
      "        default: ;",
      "      endcase",
      "      overflow  <= (cnt_outstanding >= MAX_OUT) && req && !ack;",
      "      underflow <= (cnt_outstanding == 0) && ack && !req;",
      "    end",
      "  end",
      "endmodule",
      "",
      "// --- SVA ---",
      "AST_NO_OVERFLOW:  assert property (@(posedge clk) disable iff (!rst_n) !overflow);",
      "AST_NO_UNDERFLOW: assert property (@(posedge clk) disable iff (!rst_n) !underflow);"
    ]
  },

  // ============================================================
  // Common (both modes)
  // ============================================================

  "SVA Mutex": {
    "prefix": "sva-mutex",
    "scope": "systemverilog,verilog",
    "description": "Mutual exclusion (both modes)",
    "body": [
      "// ${1:sig_a} と ${2:sig_b} は同時に立ってはいけない",
      "property prop_mutex_${1:sig_a}_${2:sig_b};",
      "  @(posedge ${3:clk}) disable iff (!${4:rst_n})",
      "  !(${1:sig_a} && ${2:sig_b});",
      "endproperty",
      "",
      "AST_MUTEX_${1/(.*)/${1:/upcase}/}_${2/(.*)/${1:/upcase}/}: assert property (prop_mutex_${1:sig_a}_${2:sig_b});"
    ]
  },

  "SVA One-Hot": {
    "prefix": "sva-onehot",
    "scope": "systemverilog,verilog",
    "description": "One-hot encoding check (both modes)",
    "body": [
      "// ${1:state} は必ず one-hot",
      "property prop_${1:state}_one_hot;",
      "  @(posedge ${2:clk}) disable iff (!${3:rst_n})",
      "  \\$onehot(${1:state});",
      "endproperty",
      "",
      "AST_${1/(.*)/${1:/upcase}/}_ONE_HOT: assert property (prop_${1:state}_one_hot);"
    ]
  },

  "SVA Sequence Block": {
    "prefix": "sva-seq",
    "scope": "systemverilog,verilog",
    "description": "Named sequence block",
    "body": [
      "sequence seq_${1:name}(${2:});",
      "  ${3:condition} ##${4:1} ${5:next_condition};",
      "endsequence"
    ]
  },

