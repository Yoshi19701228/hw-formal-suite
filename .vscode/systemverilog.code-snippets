  // FSM
  // ============================================================

  "SVA [SIM] FSM": {
    "prefix": "sva-sim-fsm",
    "scope": "systemverilog,verilog",
    "description": "[Simulator] FSM: initial state + valid encoding + deadlock + livelock + reachability",
    "body": [
      "// ============================================================",
      "// [FSM] FSM Assertions — Simulator",
      "// ============================================================",
      "localparam FSM_INIT_STATE    = ${1:8'h01};",
      "localparam FSM_PROGRESS_MASK = ${2:8'h01}; // progress states bitmask",
      "localparam FSM_MAX_NO_PROG   = ${3:32};     // livelock bound",
      "localparam FSM_STATE_W       = ${4:8};",
      "",
      "// 1. Initial State",
      "property prop_state_during_reset;",
      "  @(posedge ${5:clk})",
      "  !${6:rst_n} |-> (${7:state} == FSM_INIT_STATE);",
      "endproperty",
      "property prop_reset_to_init;",
      "  @(posedge ${5:clk})",
      "  \\$rose(${6:rst_n}) |=> (${7:state} == FSM_INIT_STATE);",
      "endproperty",
      "AST_STATE_IN_RESET: assert property (prop_state_during_reset)",
      "  else \\$error(\"[ASSERT FAIL] STATE_IN_RESET: state=%0h at %t\", ${7:state}, \\$time);",
      "AST_RESET_TO_INIT:  assert property (prop_reset_to_init)",
      "  else \\$error(\"[ASSERT FAIL] RESET_TO_INIT: state=%0h at %t\", ${7:state}, \\$time);",
      "COV_INIT_REACHED:   cover property (@(posedge ${5:clk}) ${7:state} == FSM_INIT_STATE);",
      "",
      "// 2. Valid State Encoding (one-hot)",
      "property prop_valid_state;",
      "  @(posedge ${5:clk}) disable iff (!${6:rst_n})",
      "  \\$onehot(${7:state});",
      "endproperty",
      "AST_VALID_STATE: assert property (prop_valid_state)",
      "  else \\$error(\"[ASSERT FAIL] VALID_STATE: state=%b at %t\", ${7:state}, \\$time);",
      "",
      "// 3. Deadlock Freedom",
      "property prop_no_deadlock;",
      "  @(posedge ${5:clk}) disable iff (!${6:rst_n})",
      "  |${7:state} |-> |${8:next_state};",
      "endproperty",
      "AST_NO_DEADLOCK: assert property (prop_no_deadlock)",
      "  else \\$error(\"[ASSERT FAIL] NO_DEADLOCK: state=%b next=%b at %t\", ${7:state}, ${8:next_state}, \\$time);",
      "",
      "// 4. Livelock Freedom",
      "property prop_no_livelock;",
      "  @(posedge ${5:clk}) disable iff (!${6:rst_n})",
      "  !(|(${7:state} & FSM_PROGRESS_MASK)) |-> ##[1:FSM_MAX_NO_PROG] |(${7:state} & FSM_PROGRESS_MASK);",
      "endproperty",
      "AST_NO_LIVELOCK: assert property (prop_no_livelock)",
      "  else \\$error(\"[ASSERT FAIL] NO_LIVELOCK: no progress for >%0d cycles at %t\", FSM_MAX_NO_PROG, \\$time);",
      "COV_PROGRESS: cover property (@(posedge ${5:clk}) |(${7:state} & FSM_PROGRESS_MASK));",
      "",
      "// 5. State Reachability",
      "generate",
      "  genvar fsm_s;",
      "  for (fsm_s = 0; fsm_s < FSM_STATE_W; fsm_s++) begin : g_fsm_reach",
      "    COV_STATE_REACH: cover property (@(posedge ${5:clk}) ${7:state}[fsm_s]);",
      "  end",
      "endgenerate"
    ]
  },

  "Verilog [FORMAL] FSM Helper": {
    "prefix": "sva-fml-fsm-helper",
    "scope": "systemverilog,verilog",
    "description": "[Formal] Verilog FSM helper: deadlock flag + livelock counter + $anyconst chosen_state",
    "body": [
      "// ============================================================",
      "// [Helper Logic] FSM formal helper",
      "// ============================================================",
      "module fsm_formal_helper #(",
      "  parameter STATE_W      = ${1:8},",
      "  parameter PROGRESS_MASK = ${2:8'h01},",
      "  parameter MAX_NO_PROG  = ${3:32}",
      ") (",
      "  input  wire               clk,",
      "  input  wire               rst_n,",
      "  input  wire [STATE_W-1:0] state,",
      "  input  wire [STATE_W-1:0] next_state,",
      "  output reg                deadlock,",
      "  output reg  [\\$clog2(MAX_NO_PROG+1)-1:0] cnt_no_progress,",
      "  output reg                livelock,",
      "  output wire [STATE_W-1:0] chosen_state   // \\$anyconst: 任意の対象状態",
      ");",
      "  assign chosen_state = \\$anyconst;",
      "",
      "  // Deadlock: 有効な state なのに next_state が全ゼロ",
      "  always @(posedge clk or negedge rst_n) begin",
      "    if (!rst_n) deadlock <= 1'b0;",
      "    else        deadlock <= |state && !|next_state;",
      "  end",
      "",
      "  // Livelock: progress state を訪問しないサイクル数",
      "  wire in_progress = |(state & STATE_W'(PROGRESS_MASK));",
      "  always @(posedge clk or negedge rst_n) begin",
      "    if (!rst_n || in_progress) begin",
      "      cnt_no_progress <= '0;",
      "      livelock        <= 1'b0;",
      "    end else begin",
      "      cnt_no_progress <= cnt_no_progress + 1;",
      "      livelock        <= (cnt_no_progress >= MAX_NO_PROG - 1);",
      "    end",
      "  end",
      "endmodule"
    ]
  },

  "SVA [FORMAL] FSM": {
    "prefix": "sva-fml-fsm",
    "scope": "systemverilog,verilog",
    "description": "[Formal] FSM: initial state + deadlock + livelock (safety conversion) + reachability via $anyconst",
    "body": [
      "// ============================================================",
      "// [FSM] FSM Assertions — Formal",
      "// Requires: fsm_formal_helper providing deadlock / livelock / chosen_state",
      "// ============================================================",
      "localparam FSM_INIT_STATE    = ${1:8'h01};",
      "localparam FSM_PROGRESS_MASK = ${2:8'h01};",
      "",
      "// 1. Safety -------------------------------------------",
      "",
      "// Initial State: リセット中",
      "property prop_state_during_reset;",
      "  @(posedge ${3:clk})",
      "  !${4:rst_n} |-> (${5:state} == FSM_INIT_STATE);",
      "endproperty",
      "AST_STATE_IN_RESET: assert property (prop_state_during_reset);",
      "",
      "// Initial State: リセット解除直後",
      "property prop_reset_to_init;",
      "  @(posedge ${3:clk})",
      "  \\$rose(${4:rst_n}) |=> (${5:state} == FSM_INIT_STATE);",
      "endproperty",
      "AST_RESET_TO_INIT: assert property (prop_reset_to_init);",
      "",
      "// Valid State Encoding",
      "property prop_valid_state;",
      "  @(posedge ${3:clk}) disable iff (!${4:rst_n})",
      "  \\$onehot(${5:state});",
      "endproperty",
      "AST_VALID_STATE: assert property (prop_valid_state);",
      "",
      "// Deadlock Freedom",
      "property prop_no_deadlock;",
      "  @(posedge ${3:clk}) disable iff (!${4:rst_n})",
      "  !deadlock;",
      "endproperty",
      "AST_NO_DEADLOCK: assert property (prop_no_deadlock);",
      "",
      "// Livelock Freedom (liveness → safety 変換)",
      "property prop_no_livelock;",
      "  @(posedge ${3:clk}) disable iff (!${4:rst_n})",
      "  !livelock;",
      "endproperty",
      "AST_NO_LIVELOCK: assert property (prop_no_livelock);",
      "",
      "// 2. Reachability -------------------------------------",
      "",
      "COV_INIT_STATE:      cover property (@(posedge ${3:clk}) ${5:state} == FSM_INIT_STATE);",
      "COV_CHOSEN_STATE:    cover property (@(posedge ${3:clk}) ${5:state} == chosen_state);",
      "COV_PROGRESS:        cover property (@(posedge ${3:clk}) |(${5:state} & FSM_PROGRESS_MASK));",
      "COV_PROGRESS_CYCLE:  cover property (",
      "  @(posedge ${3:clk})",
      "  |(${5:state} & FSM_PROGRESS_MASK) ##1 !(|(${5:state} & FSM_PROGRESS_MASK))",
      "  ##[1:\\$] |(${5:state} & FSM_PROGRESS_MASK));",
      "",
      "// 3. Environment (assume) ----------------------------",
      "",
      "property assume_chosen_valid;",
      "  @(posedge ${3:clk})",
      "  \\$onehot(chosen_state);",
      "endproperty",
      "ENV_CHOSEN_VALID: assume property (assume_chosen_valid);"
    ]
  },

  "SVA [SIM] Arbiter": {
    "prefix": "sva-sim-arbiter",
    "scope": "systemverilog,verilog",
    "description": "[Simulator] Arbiter: mutex + no spurious grant + fairness (generate)",
    "body": [
      "// ============================================================",
      "// [Arbiter] ${1:N}-requester arbiter — Simulator",
      "// Signals: req[${1:N}-1:0], gnt[${1:N}-1:0]",
      "// ============================================================",
      "localparam ARB_N        = ${1:4};",
      "localparam ARB_MAX_WAIT = ${2:16};",
      "",
      "// Mutual Exclusion",
      "property prop_gnt_mutex;",
      "  @(posedge ${3:clk}) disable iff (!${4:rst_n})",
      "  \\$onehot0(${5:gnt});",
      "endproperty",
      "AST_GNT_MUTEX: assert property (prop_gnt_mutex)",
      "  else \\$error(\"[ASSERT FAIL] GNT_MUTEX: multiple grants (gnt=%b) at %t\", ${5:gnt}, \\$time);",
      "",
      "// No Spurious Grant",
      "property prop_no_spurious_gnt;",
      "  @(posedge ${3:clk}) disable iff (!${4:rst_n})",
      "  (${5:gnt} & ~${6:req}) == '0;",
      "endproperty",
      "AST_NO_SPURIOUS_GNT: assert property (prop_no_spurious_gnt)",
      "  else \\$error(\"[ASSERT FAIL] NO_SPURIOUS_GNT: gnt without req (req=%b gnt=%b) at %t\", ${6:req}, ${5:gnt}, \\$time);",
      "",
      "// Fairness (generate per port)",
      "generate",
      "  genvar arb_i;",
      "  for (arb_i = 0; arb_i < ARB_N; arb_i++) begin : g_fairness",
      "    property prop_fairness_i;",
      "      @(posedge ${3:clk}) disable iff (!${4:rst_n})",
      "      \\$rose(${6:req}[arb_i]) |-> ##[1:ARB_MAX_WAIT] ${5:gnt}[arb_i];",
      "    endproperty",
      "    AST_FAIRNESS: assert property (prop_fairness_i)",
      "      else \\$error(\"[ASSERT FAIL] FAIRNESS[%0d]: starved at %t\", arb_i, \\$time);",
      "    COV_GRANT: cover property (@(posedge ${3:clk}) \\$rose(${6:req}[arb_i]) ##[1:ARB_MAX_WAIT] ${5:gnt}[arb_i]);",
      "  end",
      "endgenerate",
      "",
      "COV_GNT_ANY:         cover property (@(posedge ${3:clk}) |${5:gnt});",
      "COV_ALL_REQ:         cover property (@(posedge ${3:clk}) &${6:req});",
      "COV_GNT_CONTENTION:  cover property (@(posedge ${3:clk}) |${5:gnt} && (${6:req} != ${5:gnt}));"
    ]
  },

  "Verilog [FORMAL] Arbiter Helper (non-determinism)": {
    "prefix": "sva-fml-arbiter-helper",
    "scope": "systemverilog,verilog",
    "description": "[Formal] Verilog arbiter helper with $anyconst non-deterministic index",
    "body": [
      "// ============================================================",
      "// [Helper Logic] Arbiter formal helper — non-determinism ($anyconst)",
      "// ============================================================",
      "module arbiter_formal_helper #(",
      "  parameter N        = ${1:4},",
      "  parameter MAX_WAIT = ${2:16}",
      ") (",
      "  input  wire         clk,",
      "  input  wire         rst_n,",
      "  input  wire [N-1:0] req,",
      "  input  wire [N-1:0] gnt,",
      "  output wire [\\$clog2(N)-1:0] chosen,",
      "  output reg  [\\$clog2(MAX_WAIT+1)-1:0] cnt_wait [0:N-1],",
      "  output reg  starvation",
      ");",
      "  // $anyconst: 全証明を通じて固定される非決定的インデックス (∀ port を一度に証明)",
      "  assign chosen = \\$anyconst;",
      "",
      "  genvar i;",
      "  generate",
      "    for (i = 0; i < N; i++) begin : g_cnt",
      "      always @(posedge clk or negedge rst_n) begin",
      "        if (!rst_n)",
      "          cnt_wait[i] <= '0;",
      "        else if (req[i] && !gnt[i])",
      "          cnt_wait[i] <= cnt_wait[i] + 1;",
      "        else",
      "          cnt_wait[i] <= '0;",
      "      end",
      "    end",
      "  endgenerate",
      "",
      "  always @(posedge clk or negedge rst_n) begin",
      "    if (!rst_n)",
      "      starvation <= 1'b0;",
      "    else",
      "      starvation <= (cnt_wait[chosen] >= MAX_WAIT - 1) && req[chosen] && !gnt[chosen];",
      "  end",
      "endmodule"
    ]
  },

  "SVA [FORMAL] Arbiter": {
    "prefix": "sva-fml-arbiter",
    "scope": "systemverilog,verilog",
    "description": "[Formal] Arbiter: mutex + no spurious + starvation-freedom via $anyconst",
    "body": [
      "// ============================================================",
      "// [Arbiter] ${1:N}-requester arbiter — Formal (non-determinism)",
      "// Requires: arbiter_formal_helper instance providing chosen / starvation",
      "// ============================================================",
      "",
      "// 1. Safety -------------------------------------------",
      "",
      "// Mutual Exclusion",
      "property prop_gnt_mutex;",
      "  @(posedge ${2:clk}) disable iff (!${3:rst_n})",
      "  \\$onehot0(${4:gnt});",
      "endproperty",
      "AST_GNT_MUTEX: assert property (prop_gnt_mutex);",
      "",
      "// No Spurious Grant",
      "property prop_no_spurious_gnt;",
      "  @(posedge ${2:clk}) disable iff (!${3:rst_n})",
      "  (${4:gnt} & ~${5:req}) == '0;",
      "endproperty",
      "AST_NO_SPURIOUS_GNT: assert property (prop_no_spurious_gnt);",
      "",
      "// Starvation-freedom (chosen port, driven by \\$anyconst)",
      "property prop_no_starvation;",
      "  @(posedge ${2:clk}) disable iff (!${3:rst_n})",
      "  !starvation;",
      "endproperty",
      "AST_NO_STARVATION: assert property (prop_no_starvation);",
      "",
      "// Grant implies Request for chosen port",
      "property prop_gnt_implies_req;",
      "  @(posedge ${2:clk}) disable iff (!${3:rst_n})",
      "  ${4:gnt}[chosen] |-> ${5:req}[chosen];",
      "endproperty",
      "AST_GNT_IMPLIES_REQ: assert property (prop_gnt_implies_req);",
      "",
      "// 2. Reachability -------------------------------------",
      "",
      "COV_CHOSEN_GNT:            cover property (@(posedge ${2:clk}) ${4:gnt}[chosen]);",
      "COV_CHOSEN_REQ:            cover property (@(posedge ${2:clk}) ${5:req}[chosen]);",
      "COV_CHOSEN_GNT_CONTENTION: cover property (@(posedge ${2:clk}) ${4:gnt}[chosen] && (${5:req} != (1 << chosen)));",
      "COV_ALL_REQ:               cover property (@(posedge ${2:clk}) &${5:req});",
      "",
      "// 3. Environment Constraints (assume) ----------------",
      "",
      "property assume_chosen_valid;",
      "  @(posedge ${2:clk}) chosen < ${1:N};",
      "endproperty",
      "ENV_CHOSEN_VALID: assume property (assume_chosen_valid);",
      "",
      "property assume_chosen_requests;",
      "  @(posedge ${2:clk}) disable iff (!${3:rst_n})",
      "  ##1 ${5:req}[chosen];",
      "endproperty",
      "ENV_CHOSEN_REQUESTS: assume property (assume_chosen_requests);"
    ]
  }
}
