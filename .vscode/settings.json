{
  // -------------------------------------------------------
  // File extension to language ID mapping
  // Must match snippet scope "systemverilog,verilog"
  // -------------------------------------------------------
  "files.associations": {
    "*.sv":  "systemverilog",
    "*.svh": "systemverilog",
    "*.v":   "verilog",
    "*.vh":  "verilog"
  },

  // -------------------------------------------------------
  // Enable snippet completion
  // -------------------------------------------------------
  "[systemverilog]": {
    "editor.snippetSuggestions": "top",
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": false
    }
  },
  "[verilog]": {
    "editor.snippetSuggestions": "top",
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": false
    }
  },

  // -------------------------------------------------------
  // Enable Copilot Instructions (auto-loaded in VS Code 1.90+)
  // -------------------------------------------------------
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,

  // -------------------------------------------------------
  // Editor settings
  // -------------------------------------------------------
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "files.trimTrailingWhitespace": true,

  // -------------------------------------------------------
  // For generate.py: pass ANTHROPIC_API_KEY to VS Code tasks
  // Recommended to manage via OS environment variable or .env rather than writing it here directly
  // -------------------------------------------------------
  "terminal.integrated.env.osx": {
    "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}"
  },
  "terminal.integrated.env.linux": {
    "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}"
  },
  "terminal.integrated.env.windows": {
    "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}"
  }
}
